@import "tailwindcss";

html {
  scroll-behavior: smooth;
  scroll-snap-type: y proximity;
}

.snap-section {
  scroll-snap-align: start;
  scroll-margin-top: 80px;
}

/* Hide scrollbar for nav */
.scrollbar-hide::-webkit-scrollbar {
    display: none;
}
.scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
}
